                                "justifyContent": "space-around",
                                "alignItems": "center",
                                "padding": "0 10px",
                                "boxSizing": "border-box"
                            },
                            "Transform_Base": { "x": 0, "y": 0, "z": 10, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
                            "Hijos": [
                                {
                                    "id": "dock_icon",
