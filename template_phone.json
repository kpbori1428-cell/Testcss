{
    "id": "escena_telefono",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "look-at-mouse": "15",
        "scroll": "2"
    },
