                "boxShadow": "0 20px 50px rgba(0,0,0,0.8), inset 0 0 0 4px #444, inset 0 0 0 8px #000",
                "position": "relative",
                "display": "flex",
                "flexDirection": "column",
                "alignItems": "center",
                "padding": "15px",
                "boxSizing": "border-box"
            },
            "Directivas_Logicas": {
