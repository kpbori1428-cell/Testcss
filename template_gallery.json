{
    "id": "galeria_3d",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "scroll": "2",
        "look-at-mouse": "15"
    },
    "Transform_Base": { "x": 0, "y": 0, "z": -500, "rx": 20, "ry": 0, "rz": 0, "scale": 1 },
    "Hijos": [
        {
            "id": "panel_principal",
            "Propiedades_Esteticas": {
                "width": "800px",
                "height": "500px",
                "background": "rgba(255, 255, 255, 0.1)",
                "backdropFilter": "blur(10px)",
                "border": "1px solid rgba(255,255,255,0.2)",
                "borderRadius": "30px",
                "display": "flex",
                "justifyContent": "space-around",
                "alignItems": "center",
                "boxShadow": "0 20px 100px rgba(0,0,0,0.8)"
            },
            "Directivas_Logicas": {
                "mouse-follow": "50"
            },
            "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
            "Hijos": [
                {
                    "id": "tarjeta",
                    "Instancias": 3,
                    "Propiedades_Esteticas": {
                        "width": "200px",
                        "height": "300px",
                        "background": "linear-gradient(135deg, #00f2fe 0%, #4facfe 100%)",
                        "borderRadius": "20px",
                        "boxShadow": "0 10px 30px rgba(0,0,0,0.5)"
                    },
                    "Directivas_Logicas": {
                        "mouse-follow": "-40",
                        "look-at-mouse": "30"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 100, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                }
            ]
        }
    ]
}