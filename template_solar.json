{
    "id": "sistema_solar",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "look-at-mouse": "60"
    },
    "Transform_Base": { "x": 0, "y": 0, "z": -200, "rx": 60, "ry": 0, "rz": 0, "scale": 1 },
    "Hijos": [
        {
            "id": "sol",
            "Propiedades_Esteticas": {
                "width": "150px",
                "height": "150px",
                "background": "radial-gradient(circle, #ffcc00, #ff6600)",
                "borderRadius": "50%",
                "boxShadow": "0 0 100px #ff9900"
            },
            "Directivas_Logicas": {
                "mouse-follow": "20"
            },
            "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
            "Hijos": [
                {
                    "id": "orbita_1",
                    "Propiedades_Esteticas": {
                        "width": "400px",
                        "height": "400px",
                        "border": "2px dashed rgba(255,255,255,0.2)",
                        "borderRadius": "50%",
                        "position": "absolute",
                        "top": "-125px",
                        "left": "-125px"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
                    "Hijos": [
                        {
                            "id": "planeta_1",
                            "Propiedades_Esteticas": {
                                "width": "40px",
                                "height": "40px",
                                "background": "linear-gradient(to right, #43e97b 0%, #38f9d7 100%)",
                                "borderRadius": "50%",
                                "position": "absolute",
                                "top": "0",
                                "left": "180px",
                                "boxShadow": "0 0 20px #38f9d7"
                            },
                            "Directivas_Logicas": {
                                "mouse-follow": "-50"
                            },
                            "Transform_Base": { "x": 0, "y": 0, "z": 50, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                        }
                    ]
                },
                {
                    "id": "orbita_2",
                    "Propiedades_Esteticas": {
                        "width": "600px",
                        "height": "600px",
                        "border": "1px solid rgba(255,255,255,0.1)",
                        "borderRadius": "50%",
                        "position": "absolute",
                        "top": "-225px",
                        "left": "-225px"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": -50, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
                    "Hijos": [
                        {
                            "id": "planeta_2",
                            "Propiedades_Esteticas": {
                                "width": "60px",
                                "height": "60px",
                                "background": "linear-gradient(to top, #fcc5e4 0%, #fda34b 15%, #ff7882 35%, #c8699e 52%, #7046aa 71%, #0c1db8 87%, #020f75 100%)",
                                "borderRadius": "50%",
                                "position": "absolute",
                                "bottom": "50px",
                                "right": "50px",
                                "boxShadow": "0 0 30px #fda34b"
                            },
                            "Directivas_Logicas": {
                                "look-at-mouse": "-90"
                            },
                            "Transform_Base": { "x": 0, "y": 0, "z": 80, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                        }
                    ]
                }
            ]
        }
    ]
}