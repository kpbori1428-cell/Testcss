{
    "id": "background_scene",
    "props": {
        "width": "100%", "height": "100%",
        "backgroundColor": "#000511",
        "overflow": "hidden"
    },
    "children": [
        {
            "id": "starfield",
            "logic": { "instancias": 150 },
            "template": "V4_STAR",
            "props": {
                "transform": {
                    "translateX": "=sin(index * 1.7) * 1000",
                    "translateY": "=cos(index * 2.3) * 1000",
                    "translateZ": "=index * -10 - 200",
                    "scale": "=0.5 + (index / total) * 1.5"
                },
                "opacity": "=0.2 + (index / total) * 0.8"
            }
        },
        {
            "id": "hero",
            "props": {
                "width": "100%", "height": "100%",
                "display": "flex", "justifyContent": "center", "alignItems": "center",
                "color": "white",
                "fontSize": "40px",
                "fontWeight": "bold",
                "textShadow": "0 0 20px cyan"
            },
            "logic": {
                "float": { "amplitude": 30, "speed": 1.5 }
            },
            "children": [
                { "id": "title", "props": { "innerHTML": "Interactive 3D Background" } }
            ]
        }
    ]
}
