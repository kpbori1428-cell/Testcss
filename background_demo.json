{
    "id": "background_scene",
    "props": {
        "width": "100%", "height": "100%",
        "backgroundColor": "#000308",
        "overflow": "hidden"
    },
    "children": [
        {
            "id": "star",
            "logic": {
                "instancias": 100,
                "recycle": { "thresholdZ": 500, "resetZ": -1500, "randomizeXY": true, "rangeX": 2000, "rangeY": 2000 }
            },
            "template": "V4_STAR",
            "props": {
                "transform": {
                    "translateX": "=sin(index * 1.7) * 800",
                    "translateY": "=cos(index * 2.3) * 800",
                    "translateZ": "=index * -15",
                    "rotateZ": "=index * 10"
                },
                "opacity": "=0.3 + (index / total) * 0.7"
            },
            "children": [
                {
                    "id": "mover",
                    "props": {
                        "transform": {
                            "translateZ": "=time * 300"
                        }
                    }
                }
            ]
        },
        {
            "id": "hero",
            "props": {
                "width": "100%", "height": "100%",
                "display": "flex", "justifyContent": "center", "alignItems": "center",
                "color": "white", "fontSize": "42px", "fontWeight": "bold",
                "textShadow": "0 0 30px #00ffff",
                "pointerEvents": "none"
            },
            "logic": { "float": { "amplitude": 20, "speed": 1 } },
            "children": [
                { "id": "t", "props": { "innerHTML": "Infinite Object Pooling" } }
            ]
        }
    ]
}
