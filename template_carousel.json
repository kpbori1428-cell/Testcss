{
    "id": "carrusel_inmersivo",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "look-at-mouse": "40"
    },
    "Transform_Base": { "x": 0, "y": 0, "z": -400, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
    "Hijos": [
        {
            "id": "pivote_carrusel",
            "Propiedades_Esteticas": {
                "width": "0px",
                "height": "0px"
            },
            "Directivas_Logicas": {
                "mouse-follow": "20",
                "scroll": "5"
            },
            "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
            "Hijos": [
                {
                    "id": "panel_0",
                    "Propiedades_Esteticas": { "width": "200px", "height": "300px", "background": "rgba(255,0,0,0.5)", "border": "2px solid red", "position": "absolute" },
                    "Transform_Base": { "x": 0, "y": 0, "z": 300, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                },
                {
                    "id": "panel_60",
