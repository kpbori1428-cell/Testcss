                    "Transform_Base": { "x": 0, "y": 0, "z": 300, "rx": 0, "ry": 60, "rz": 0, "scale": 1 }
                },
                {
                    "id": "panel_120",
                    "Propiedades_Esteticas": { "width": "200px", "height": "300px", "background": "rgba(255,255,0,0.5)", "border": "2px solid yellow", "position": "absolute" },
                    "Transform_Base": { "x": 0, "y": 0, "z": 300, "rx": 0, "ry": 120, "rz": 0, "scale": 1 }
                },
                {
