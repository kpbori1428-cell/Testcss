                },
                {
                    "id": "panel_300",
                    "Propiedades_Esteticas": { "width": "200px", "height": "300px", "background": "rgba(128,0,128,0.5)", "border": "2px solid purple", "position": "absolute" },
                    "Transform_Base": { "x": 0, "y": 0, "z": 300, "rx": 0, "ry": 300, "rz": 0, "scale": 1 }
                }
            ]
        }
    ]
}