{
    "id": "app_view_flappy",
    "App_Logic": "Flappy",
    "Propiedades_Esteticas": {
        "width": "100%",
        "flex": "1",
        "position": "absolute",
        "height": "100%",
        "top": "0",
        "left": "0",
        "background": "#71c5cf",
        "fontFamily": "sans-serif",
        "overflow": "hidden",
        "display": "block",
        "pointerEvents": "auto",
        "cursor": "pointer"
    },
    "Transform_Base": {
        "x": 0, "y": 0, "z": 5, "rx": 0, "ry": 0, "rz": 0, "scale": 1
    },
    "Hijos": [
        {
            "id": "puntuacion",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "top": "10%",
                "left": "50%",
                "transform": "translateX(-50%)",
                "fontSize": "48px",
                "fontWeight": "bold",
                "color": "white",
                "textShadow": "2px 2px 0 #000, -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000",
                "zIndex": "10",
                "pointerEvents": "none"
            },
            "innerHTML": "0"
        },
        {
            "id": "pantalla_gameover",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "top": "40%",
                "left": "50%",
                "transform": "translate(-50%, -50%)",
                "width": "80%",
                "background": "#ded895",
                "border": "4px solid #543847",
                "borderRadius": "10px",
                "padding": "20px",
                "textAlign": "center",
                "zIndex": "20",
                "display": "none",
                "boxShadow": "0 5px 15px rgba(0,0,0,0.5)"
            },
            "Hijos": [
                {
                    "id": "texto_gameover",
                    "Propiedades_Esteticas": {
                        "fontSize": "24px",
                        "fontWeight": "bold",
                        "color": "#e06336",
                        "textShadow": "1px 1px 0 #fff",
                        "marginBottom": "15px"
                    },
                    "innerHTML": "Game Over"
                },
                {
                    "id": "btn_reiniciar",
                    "Propiedades_Esteticas": {
                        "display": "inline-block",
                        "background": "#f17922",
                        "color": "white",
                        "padding": "10px 20px",
                        "fontSize": "18px",
                        "fontWeight": "bold",
                        "border": "2px solid white",
                        "borderRadius": "5px",
                        "cursor": "pointer"
                    },
                    "innerHTML": "Reintentar"
                }
            ]
        },
        {
            "id": "pajaro",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "width": "34px",
                "height": "24px",
                "background": "#f3c72b",
                "border": "2px solid #543847",
                "borderRadius": "50% 50% 40% 40%",
                "left": "50px",
                "top": "200px",
                "zIndex": "5",
                "transition": "none"
            },
            "Hijos": [
                {
                    "id": "ojo_pajaro",
                    "Propiedades_Esteticas": {
                        "position": "absolute",
                        "width": "8px",
                        "height": "8px",
                        "background": "white",
                        "border": "1px solid #000",
                        "borderRadius": "50%",
                        "top": "4px",
                        "right": "6px"
                    },
                    "Hijos": [
                        {
                            "id": "pupila_pajaro",
                            "Propiedades_Esteticas": {
                                "position": "absolute",
                                "width": "3px",
                                "height": "3px",
                                "background": "black",
                                "borderRadius": "50%",
                                "top": "2px",
                                "right": "1px"
                            }
                        }
                    ]
                },
                {
                    "id": "pico_pajaro",
                    "Propiedades_Esteticas": {
                        "position": "absolute",
                        "width": "12px",
                        "height": "8px",
                        "background": "#f17922",
                        "border": "1px solid #543847",
                        "borderRadius": "4px",
                        "top": "10px",
                        "right": "-6px"
                    }
                },
                {
                    "id": "ala_pajaro",
                    "Propiedades_Esteticas": {
                        "position": "absolute",
                        "width": "14px",
                        "height": "8px",
                        "background": "white",
                        "border": "1px solid #543847",
                        "borderRadius": "50%",
                        "top": "10px",
                        "left": "4px"
                    }
                }
            ]
        },
        {
            "id": "nubes",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "bottom": "100px",
                "left": "0",
                "width": "100%",
                "height": "60px",
                "background": "url('data:image/svg+xml;utf8,<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"200\" height=\"60\"><circle cx=\"30\" cy=\"60\" r=\"25\" fill=\"%23e0f6f9\"/><circle cx=\"70\" cy=\"60\" r=\"35\" fill=\"%23e0f6f9\"/><circle cx=\"120\" cy=\"60\" r=\"20\" fill=\"%23e0f6f9\"/></svg>') repeat-x",
                "backgroundPosition": "bottom",
                "zIndex": "1",
                "opacity": "0.7",
                "pointerEvents": "none"
            }
        },
        {
            "id": "suelo",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "bottom": "0",
                "left": "0",
                "width": "100%",
                "height": "100px",
                "background": "repeating-linear-gradient(-45deg, #ded895, #ded895 20px, #e4de9d 20px, #e4de9d 40px)",
                "borderTop": "4px solid #73bf2e",
                "zIndex": "10",
                "pointerEvents": "none"
            }
        },
        {
            "id": "tuberias_contenedor",
            "Propiedades_Esteticas": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "calc(100% - 100px)",
                "zIndex": "2",
                "overflow": "visible",
                "pointerEvents": "none"
            }
        }
    ]
}
