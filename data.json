{
    "id": "escena_principal",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "mouse-follow": "20"
    },
    "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
    "Hijos": [
        {
            "id": "cubo_3d",
            "Propiedades_Esteticas": {
                "width": "200px",
                "height": "200px",
                "transformStyle": "preserve-3d"
            },
            "Directivas_Logicas": {
                "look-at-mouse": "90"
            },
            "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": -30, "ry": 45, "rz": 0, "scale": 1 },
            "Hijos": [
                {
                    "id": "front",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(255, 0, 204, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 100, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                },
                {
                    "id": "back",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(51, 51, 255, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": -100, "rx": 0, "ry": 180, "rz": 0, "scale": 1 }
                },
                {
                    "id": "right",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(0, 255, 0, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": 100, "y": 0, "z": 0, "rx": 0, "ry": 90, "rz": 0, "scale": 1 }
                },
                {
                    "id": "left",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(255, 255, 0, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": -100, "y": 0, "z": 0, "rx": 0, "ry": -90, "rz": 0, "scale": 1 }
                },
                {
                    "id": "top",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(0, 255, 255, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": 0, "y": -100, "z": 0, "rx": 90, "ry": 0, "rz": 0, "scale": 1 }
                },
                {
                    "id": "bottom",
                    "Propiedades_Esteticas": {
                        "position": "absolute", "width": "200px", "height": "200px",
                        "background": "rgba(255, 0, 0, 0.7)", "border": "2px solid #fff",
                        "display": "flex", "justifyContent": "center", "alignItems": "center", "fontSize": "24px", "color": "white"
                    },
                    "Transform_Base": { "x": 0, "y": 100, "z": 0, "rx": -90, "ry": 0, "rz": 0, "scale": 1 }
                }
            ]
        }
    ]
}
