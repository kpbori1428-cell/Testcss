{
    "id": "ciudad_abstracta",
    "Propiedades_Esteticas": {
        "width": "100%",
        "height": "100%",
        "display": "flex",
        "justifyContent": "center",
        "alignItems": "center"
    },
    "Directivas_Logicas": {
        "scroll": "5",
        "look-at-mouse": "45"
    },
    "Transform_Base": { "x": 0, "y": 100, "z": -600, "rx": 50, "ry": -10, "rz": 0, "scale": 1 },
    "Hijos": [
        {
            "id": "base_suelo",
            "Propiedades_Esteticas": {
                "width": "800px",
                "height": "800px",
                "background": "linear-gradient(to right, #0f2027, #203a43, #2c5364)",
                "border": "1px solid rgba(0, 255, 255, 0.2)",
                "boxShadow": "0 0 100px rgba(0,0,0,0.9)",
                "display": "grid",
                "gridTemplateColumns": "repeat(4, 1fr)",
                "gridTemplateRows": "repeat(4, 1fr)",
                "gap": "20px",
                "padding": "40px"
            },
            "Directivas_Logicas": {
                "mouse-follow": "30"
            },
            "Transform_Base": { "x": 0, "y": 0, "z": 0, "rx": 0, "ry": 0, "rz": 0, "scale": 1 },
            "Hijos": [
                {
                    "id": "edificio_chico",
                    "Instancias": 5,
                    "Propiedades_Esteticas": {
                        "width": "100%",
                        "height": "100%",
                        "background": "rgba(0, 255, 255, 0.1)",
                        "border": "2px solid #00ffff",
                        "boxShadow": "inset 0 0 20px rgba(0,255,255,0.5)"
                    },
                    "Directivas_Logicas": {
                        "look-at-mouse": "-20"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 50, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                },
                {
                    "id": "edificio_mediano",
                    "Instancias": 5,
                    "Propiedades_Esteticas": {
                        "width": "100%",
                        "height": "100%",
                        "background": "rgba(255, 0, 255, 0.1)",
                        "border": "2px solid #ff00ff",
                        "boxShadow": "inset 0 0 20px rgba(255,0,255,0.5)"
                    },
                    "Directivas_Logicas": {
                        "mouse-follow": "-40"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 150, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                },
                {
                    "id": "edificio_alto",
                    "Instancias": 6,
                    "Propiedades_Esteticas": {
                        "width": "100%",
                        "height": "100%",
                        "background": "rgba(255, 255, 0, 0.1)",
                        "border": "2px solid #ffff00",
                        "boxShadow": "inset 0 0 20px rgba(255,255,0,0.5)"
                    },
                    "Directivas_Logicas": {
                        "look-at-mouse": "40",
                        "mouse-follow": "20"
                    },
                    "Transform_Base": { "x": 0, "y": 0, "z": 250, "rx": 0, "ry": 0, "rz": 0, "scale": 1 }
                }
            ]
        }
    ]
}